[ sql ] [ SQL ] INSERT INTO `wolive_chats` (`visiter_id` , `content` , `unstr` , `business_id` , `service_id` , `direction` , `timestamp` , `type`) VALUES ('67c1d9acqgvefd42fm0' , '<p>有一天，小明去参加一个重要的面试。面试官问他：“你有什么特长？”</p>\n\n<p>小明想了想，自信地回答：“我会模仿动物叫声。”</p>\n\n<p>面试官好奇地说：“那请你模仿一下。”</p>\n\n<p>小明立刻站起来，模仿了一只狗的叫声：“汪！汪！”</p>\n\n<p>面试官点点头：“不错，还有吗？”</p>\n\n<p>小明又模仿了一只猫的叫声：“喵~喵~”</p>\n\n<p>面试官笑了笑：“很好，还有吗？”</p>\n\n<p>小明深吸一口气，突然模仿了一只羊的叫声：“咩~~~”</p>\n\n<p>面试官忍不住笑出声来：“很好，你被录用了！”</p>\n\n<p>小明惊讶地问：“真的吗？为什么？”</p>\n\n<p>面试官笑着说：“因为我们公司正好缺一个‘羊’（样）板员工！”</p>\n\n<p>小明：“……”</p>' , '2bda5508e3ecb872da1f15e3eb6529f4' , 1 , 1 , 'to_visiter' , 1741289378 , 2) [ RunTime:0.000754s ]
