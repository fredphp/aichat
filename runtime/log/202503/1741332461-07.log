[ sql ] [ SQL ] INSERT INTO `wolive_chats` (`visiter_id` , `content` , `unstr` , `business_id` , `service_id` , `direction` , `timestamp` , `type`) VALUES ('67c1d9acqgvefd42fm0' , '<p>从前，在一个遥远的村庄里，住着一位名叫小明的男孩。小明非常喜欢探险，一天，他决定去森林深处寻找传说中的神秘宝藏。他带上了地图和干粮，勇敢地踏上了旅程。</p>\n\n<p>在森林里，小明遇到了许多困难，比如湍急的河流和茂密的荆棘。但他没有放弃，用智慧和勇气一一克服。终于，他来到了一个古老的洞穴前。</p>\n\n<p>洞穴里漆黑一片，小明点燃了火把，小心翼翼地走进去。在洞穴的深处，他发现了一个闪闪发光的宝箱。打开宝箱后，里面装满了金币和宝石。</p>\n\n<p>小明高兴极了，但他并没有贪心，只拿了几枚金币作为纪念。他知道，真正的宝藏是这次冒险的经历和学到的勇气与智慧。</p>\n\n<p>回到家后，小明把这次冒险的故事告诉了村里的孩子们，大家都为他感到骄傲。从此，小明成了村里的英雄，他的故事也被一代代传颂下去。</p>' , '6e8cb3e7bf04f7f2a0ec214c725f08da' , 1 , 1 , 'to_visiter' , 1741289325 , 2) [ RunTime:0.000670s ]
---------------------------------------------------------------
